#!/usr/bin/env node

const childProcess = require("child_process")
const fs = require("fs")
const path = require("path")

function run(target, args = process.argv.slice(2)) {
  const result = childProcess.spawnSync(target, args, {
    stdio: "inherit",
  })

  if (result.error) {
    console.error(result.error.message)
    process.exit(1)
  }

  process.exit(typeof result.status === "number" ? result.status : 0)
}

const envPath = process.env.OPENHACKER_BIN_PATH
if (envPath) {
  run(envPath)
}

const scriptDir = path.dirname(fs.realpathSync(__filename))
const cliEntry = path.join(scriptDir, "..", "src", "cli.ts")
const fallback = childProcess.spawnSync("bun", ["run", cliEntry, ...process.argv.slice(2)], {
  stdio: "inherit",
})

if (fallback.error) {
  console.error(
    "Bun is not installed. Install Bun or use the release installer at https://openhacker.ai/install.",
  )
  process.exit(1)
}

process.exit(typeof fallback.status === "number" ? fallback.status : 0)
