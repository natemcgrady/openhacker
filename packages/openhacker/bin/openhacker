#!/usr/bin/env node

const childProcess = require("child_process")
const fs = require("fs")
const os = require("os")
const path = require("path")

function run(target, args = process.argv.slice(2)) {
  const result = childProcess.spawnSync(target, args, {
    stdio: "inherit",
  })

  if (result.error) {
    console.error(result.error.message)
    process.exit(1)
  }

  process.exit(typeof result.status === "number" ? result.status : 0)
}

const envPath = process.env.OPENHACKER_BIN_PATH
if (envPath) {
  run(envPath)
}

const scriptPath = fs.realpathSync(__filename)
const scriptDir = path.dirname(scriptPath)
const cachedBinary = path.join(scriptDir, ".openhacker")

if (fs.existsSync(cachedBinary)) {
  run(cachedBinary)
}

const platformMap = {
  darwin: "darwin",
  linux: "linux",
  win32: "windows",
}

const archMap = {
  arm64: "arm64",
  x64: "x64",
}

const platform = platformMap[os.platform()] || os.platform()
const arch = archMap[os.arch()] || os.arch()
const packageName = `openhacker-${platform}-${arch}`
const binaryName = platform === "windows" ? "openhacker.exe" : "openhacker"

function findBinary(startDir) {
  let current = startDir

  for (;;) {
    const candidate = path.join(current, "node_modules", packageName, "bin", binaryName)
    if (fs.existsSync(candidate)) {
      return candidate
    }

    const parent = path.dirname(current)
    if (parent === current) {
      return null
    }

    current = parent
  }
}

const resolvedBinary = findBinary(scriptDir)
if (resolvedBinary) {
  run(resolvedBinary)
}

const cliEntry = path.join(scriptDir, "..", "src", "cli.ts")
const bunFallback = childProcess.spawnSync("bun", ["run", cliEntry, ...process.argv.slice(2)], {
  stdio: "inherit",
})

if (bunFallback.error) {
  console.error(
    "No standalone OpenHacker binary was found and Bun is not installed. Install Bun or use the release installer.",
  )
  process.exit(1)
}

process.exit(typeof bunFallback.status === "number" ? bunFallback.status : 0)
